-- Function to get or CREATE Dance Remotes
local function getOrCreateRemotes()
    local char = player.Character
    if not char then return nil, nil end
    
    local danceRemote = char:FindFirstChild("Dance")
    if not danceRemote then
        danceRemote = Instance.new("RemoteEvent")
        danceRemote.Name = "Dance"
        danceRemote.Parent = char
    end
    
    local undanceRemote = char:FindFirstChild("UnDance")
    if not undanceRemote then
        undanceRemote = Instance.new("RemoteEvent")
        undanceRemote.Name = "UnDance"
        undanceRemote.Parent = char
    end
    
    return danceRemote, undanceRemote
end

-- Toggle Function
local function toggleDance()
    dancing = not dancing
    local danceRemote, undanceRemote = getOrCreateRemotes()
    
    if dancing then
        if not danceRemote then
            toggleButton.Text = "ERROR"
            dancing = false
            return
        end
        
        toggleButton.Text = "ON"
        toggleButton.BackgroundColor3 = Color3.fromRGB(0, 190, 0)
        status.Text = "Dancing... (All Classes)"
        
        -- Fire remote for server sync + sound
        danceRemote:FireServer()
        
        -- Load real Assassin Dance animation
        local char = player.Character
        local humanoid = char and char:WaitForChild("Humanoid", 2)
        if humanoid then
            local success, track = pcall(function()
                local anim = game.ReplicatedStorage.Animations:WaitForChild("Assassin Dance")
                return humanoid:LoadAnimation(anim)
            end)
            
            if success and track then
                danceTrack = track
                danceTrack:Play()
                danceTrack.Looped = true
                danceTrack:AdjustSpeed(currentSpeed)
            else
                status.Text = "Animation not found!"
            end
        end
        
        -- Keep spamming remote
        if danceConnection then
            danceConnection:Disconnect()
        end
        danceConnection = game:GetService("RunService").Heartbeat:Connect(function()
            if dancing and danceRemote then
                danceRemote:FireServer()
            end
        end)
        
    else
        toggleButton.Text = "OFF"
        toggleButton.BackgroundColor3 = Color3.fromRGB(200, 0, 0)
        status.Text = "Stopped"
        
        if danceConnection then
            danceConnection:Disconnect()
            danceConnection = nil
        end
        
        if danceTrack then
            danceTrack:Stop()
            danceTrack = nil
        end
        
        if undanceRemote then
            undanceRemote:FireServer()
        end
    end
end

toggleButton.MouseButton1Click:Connect(toggleDance)

