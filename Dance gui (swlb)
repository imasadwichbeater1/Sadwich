-- ================== FUNCTIONS ==================
local function getOrCreateRemotes()
    local char = player.Character
    if not char then return nil, nil end
    local danceRemote = char:FindFirstChild("Dance") or Instance.new("RemoteEvent")
    danceRemote.Name = "Dance"; danceRemote.Parent = char
    local undanceRemote = char:FindFirstChild("UnDance") or Instance.new("RemoteEvent")
    undanceRemote.Name = "UnDance"; undanceRemote.Parent = char
    return danceRemote, undanceRemote
end

local function applyRotationFix(char)
    rootPart = char:FindFirstChild("HumanoidRootPart")
    humanoid = char:FindFirstChild("Humanoid")
    if not rootPart or not humanoid then return end
    humanoid.AutoRotate = false
    humanoid.PlatformStand = true
    humanoid:ChangeState(Enum.HumanoidStateType.Physics)
    rootPart.CanCollide = false
    -- Extra mid-air stability
    rootPart.AssemblyLinearVelocity = Vector3.new(0, rootPart.AssemblyLinearVelocity.Y, 0)
end

local function updateAxisSelection()
    xSel.BackgroundColor3 = (selectedAxis == "X" and Color3.fromRGB(80,80,80) or Color3.fromRGB(35,35,35))
    ySel.BackgroundColor3 = (selectedAxis == "Y" and Color3.fromRGB(80,80,80) or Color3.fromRGB(35,35,35))
    zSel.BackgroundColor3 = (selectedAxis == "Z" and Color3.fromRGB(80,80,80) or Color3.fromRGB(35,35,35))
end

local function startRotation(char)
    if rotationConnection then rotationConnection:Disconnect() end
    applyRotationFix(char)
    accumulatedRot = Vector3.new(0, 0, 0)
    
    rotationConnection = game:GetService("RunService").Stepped:Connect(function(dt)
        if not (dancing and isRotating and rootPart) then return end
        
        local delta = Vector3.new(0, 0, 0)
        if isFrozen then
            -- Freeze: ONLY rotate the SELECTED axis at freezeSpeed. Others stay frozen.
            if selectedAxis == "X" then
                delta = Vector3.new(freezeSpeed, 0, 0) * dt
            elseif selectedAxis == "Y" then
                delta = Vector3.new(0, freezeSpeed, 0) * dt
            elseif selectedAxis == "Z" then
                delta = Vector3.new(0, 0, freezeSpeed) * dt
            end
        else
            -- Normal mode: all axes
            delta = Vector3.new(rotX, rotY, rotZ) * dt
        end
        
        accumulatedRot += delta
        local pos = rootPart.Position
        local newCFrame = CFrame.new(pos) * CFrame.Angles(math.rad(accumulatedRot.X), math.rad(accumulatedRot.Y), math.rad(accumulatedRot.Z))
        rootPart.CFrame = newCFrame
    end)
end

local function stopRotation()
    if rotationConnection then
        rotationConnection:Disconnect()
        rotationConnection = nil
    end
    if humanoid then
        humanoid.AutoRotate = true
        humanoid.PlatformStand = false
        humanoid:ChangeState(Enum.HumanoidStateType.Running)
    end
    if rootPart then rootPart.CanCollide = true end
    accumulatedRot = Vector3.new(0, 0, 0)
end

local function toggleDance()
    dancing = not dancing
    local danceRemote, undanceRemote = getOrCreateRemotes()
    
    if dancing then
        toggleButton.Text = "ON"
        toggleButton.BackgroundColor3 = Color3.fromRGB(0, 190, 0)
        status.Text = "Dancing... (All Classes)"
        danceRemote:FireServer()
        
        local char = player.Character
        if char then
            humanoid = char:WaitForChild("Humanoid", 2)
            rootPart = char:WaitForChild("HumanoidRootPart", 2)
            local success, track = pcall(function()
                local anim = game.ReplicatedStorage.Animations:WaitForChild("Assassin Dance")
                return humanoid:LoadAnimation(anim)
            end)
            if success and track then
                danceTrack = track
                danceTrack:Play()
                danceTrack.Looped = true
                danceTrack:AdjustSpeed(currentSpeed)
            end
        end
        if isRotating then startRotation(char) end
        
        if danceConnection then danceConnection:Disconnect() end
        danceConnection = game:GetService("RunService").Heartbeat:Connect(function()
            if dancing and danceRemote then danceRemote:FireServer() end
        end)
    else
        toggleButton.Text = "OFF"
        toggleButton.BackgroundColor3 = Color3.fromRGB(200, 0, 0)
        status.Text = "Stopped"
        if danceConnection then danceConnection:Disconnect() end
        stopRotation()
        if danceTrack then danceTrack:Stop() end
        if undanceRemote then undanceRemote:FireServer() end
    end
end

