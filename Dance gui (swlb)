-- Respawn handling (improved)
player.CharacterAdded:Connect(function()
    task.wait(1.5)
    local char = player.Character
    if not char then return end
    
    if dancing then
        -- Re-toggle to restart properly on new character
        dancing = false
        if danceConnection then
            danceConnection:Disconnect()
            danceConnection = nil
        end
        if danceTrack then
            danceTrack:Stop()
            danceTrack = nil
        end
        task.wait(0.3)
        toggleDance()  -- turn back on
    end
end)

-- Cleanup on character removing
player.CharacterRemoving:Connect(function()
    if danceConnection then
        danceConnection:Disconnect()
        danceConnection = nil
    end
    if danceTrack then
        danceTrack:Stop()
        danceTrack = nil
    end
end)

